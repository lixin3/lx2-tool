{
  "name": "lx2-tool",
  "version": "1.0.8",
  "description": "My utility library",
  "type": "module",
  "main": "./dist/my-utils.umd.js",
  "module": "./dist/my-utils.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/my-utils.es.js",
      "require": "./dist/my-utils.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^4.0.0",
    "terser": "^5.0.0"
  }
}